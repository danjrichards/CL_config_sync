# dr_config_sync.py configuration — copy to `.env` and fill in.
# Load with:  set -a; source .env; set +a
#
# All values can also be passed as CLI flags (flags win over env vars).

# ---- Source cluster (where the real topics live) ----
CL_SOURCE_REST=https://pkc-xxxxxx.<region>.<cloud>.confluent.cloud:443
CL_SOURCE_CLUSTER=lkc-xxxxxxx
CL_SOURCE_API_KEY=YOUR_SOURCE_KEY
CL_SOURCE_API_SECRET=YOUR_SOURCE_SECRET

# ---- Destination / DR cluster (must be Dedicated for CL) ----
CL_DEST_REST=https://pkc-yyyyyy.<region>.<cloud>.confluent.cloud:443
CL_DEST_CLUSTER=lkc-yyyyyyy
CL_DEST_API_KEY=YOUR_DEST_KEY
CL_DEST_API_SECRET=YOUR_DEST_SECRET

# ---- Cluster link (name of the link on the destination cluster) ----
CL_LINK=my-link

# ---- Topics to reconcile (space-separated) ----
# Either bare source names (mirror assumed same name), or source=mirror pairs.
CL_TOPICS=orders payments inventory

# ---- Optional ----
# Prefix for mirror topic names, if the link was created with cluster.link.prefix.
CL_MIRROR_PREFIX=
# Space-separated Independent configs to NOT copy onto mirrors.
# Defaults (if unset) to a conservative cluster-local set — see DEFAULT_SKIP_CONFIGS.
CL_SKIP=leader.replication.throttled.replicas follower.replication.throttled.replicas confluent.placement.constraints internal.segment.bytes
# CA bundle path (PEM). Auto-detected if omitted; set if TLS verification fails.
CL_CA_BUNDLE=
